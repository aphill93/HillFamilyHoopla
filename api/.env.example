# ============================================================
# HillFamilyHoopla API — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
# Full connection string takes precedence if set
DATABASE_URL=postgresql://hoopla:hoopla_dev_secret@localhost:5432/hillfamilyhoopla
# Or individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hillfamilyhoopla
DB_USER=hoopla
DB_PASSWORD=hoopla_dev_secret
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redis_dev_secret@localhost:6379
REDIS_PASSWORD=redis_dev_secret

# ─── JWT (RS256 — generate with: openssl genrsa -out jwt_private.pem 2048) ────
JWT_PRIVATE_KEY_PATH=./certs/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./certs/jwt_public.pem
# Or inline (base64-encoded PEM), useful for containers:
# JWT_PRIVATE_KEY_BASE64=
# JWT_PUBLIC_KEY_BASE64=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
JWT_ISSUER=hillfamilyhoopla
JWT_AUDIENCE=hillfamilyhoopla-app

# ─── mTLS (mutual TLS for iOS client pinning) ────────────────────────────────
MTLS_ENABLED=false
MTLS_CA_CERT_PATH=./certs/ca.crt
MTLS_SERVER_CERT_PATH=./certs/server.crt
MTLS_SERVER_KEY_PATH=./certs/server.key

# ─── Password hashing ────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Encryption (AES-256-GCM) ────────────────────────────────────────────────
# Must be exactly 32 bytes (256 bits). Generate with:
# node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
ENCRYPTION_KEY=your_32_byte_hex_key_here_000000000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
# Auth endpoints get a tighter limit
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=300000

# ─── Account Lockout ─────────────────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_DURATION_MS=900000

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=noreply@hillfamilyhoopla.com
EMAIL_FROM_NAME=HillFamilyHoopla

# ─── App ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
# Set to true to require an invite code for registration
REQUIRE_INVITE_CODE=false
INVITE_CODE=

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true
