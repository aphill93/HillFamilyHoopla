{
  "name": "@hillfamilyhoopla/api",
  "version": "1.0.0",
  "description": "HillFamilyHoopla API server (Fastify)",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "db:migrate": "node --env-file=.env --import tsx/esm src/db/migrate.ts",
    "db:migrate:reset": "node --env-file=.env --import tsx/esm src/db/migrate.ts --reset",
    "db:seed": "node --env-file=.env --import tsx/esm src/db/seed.ts",
    "db:seed:clean": "node --env-file=.env --import tsx/esm src/db/seed.ts --clean",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.0",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.2.0",
    "@fastify/swagger": "^9.3.0",
    "@fastify/swagger-ui": "^5.2.0",
    "@hillfamilyhoopla/shared": "*",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1",
    "pino-pretty": "^13.1.3",
    "resend": "^4.0.1",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
